<h1>HTML entry with layout variables</h1>

<h2>Some root collection entry titles</h2>

<ul>
  {% for entry in collections.root.entries limit: 2 -%}
    <li>
      <span class="title">{{ entry.title }}</span>

      <span class="published-at">
        Published at &nbsp;
        <time datetime={{ entry.published_at | date_to_xmlschema }}>{{ entry.published_at }}</time>
      </span>

      {% if entry.updated_at -%}
        <span class="updated-at">
          Updated at &nbsp;
          <time datetime={{ entry.updated_at | date_to_xmlschema }}>{{ entry.updated_at }}</time>
        </span>
      {%- endif %}

      <span class="authors">
        Authored by &nbsp;
      {% for author in entry.authors -%}
        {% if author.avatar -%}
          <img alt="" src="{{ author.avatar }}">
        {%- endif -%}

        <span class="author">{{ author.name }}</span>

        {% if author.url -%}
          (<a class="url" href="{{ author.url }}">link</a>)
        {%- endif %}
      {%- endfor %}
    </li>
  {%- endfor %}
</ul>


<h2>All collection names</h2>

{% for collection in collections -%}
  {% if forloop.last -%}
    {{ collection.name }}
  {%- else -%}
    {{ collection.name | append: ", " }}
  {%- endif %}
{%- endfor %}

<h2>All tag names</h2>

{% for tag in tags -%}
  {% if forloop.last -%}
    {{ tag.name }}
  {%- else -%}
    {{ tag.name | append: ", " }}
  {%- endif %}
{%- endfor %}

<h2>Entries for tag1</h2>

{% for entry in tags.tag1.entries -%}
  {% if forloop.last -%}
    {{ entry.title }}
  {%- else -%}
    {{ entry.title | append: ", " }}
  {%- endif %}
{%- endfor %}

<h2>This project's settings</h2>

all settings: {{ settings }}
root layout file: {{ settings.layout_file }}
root URI strategy: {{ settings.uri_strategy }}
subdirectory one URI strategy: {{ settings.subdirectory_one.uri_strategy }}

<h2>Permalinks do not include index.html because of the pretty URI strategy</h2>
{{ entry.permalink }}
